@model IEnumerable<Ator>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1>Atores -
            <a class="btn btn-dark" href="#">
                Cadastrar
            </a>
        </h1>

        <div class="col-12 my-5">
            <input class="form-control" type="text" name="nome" id="nome" placeholder="Buscar Ator"/>
        </div>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ações</th>
                    <th>Foto de Perfil</th>
                    <th>Nome</th>
                    <th>Biografia</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ator in Model)
                {
                    
                     <tr>
                        <td>
                            <div class="d-flex flex-column">
                                <a class="btn btn-info" href="#">
                                    <i class="fa-solid fa-user">
                                    </i>Editar
                                </a>
                                <br />
                                <a class="btn btn-danger" href="#"> 
                                    <i class="fa-solid fa-trash-can">
                                </i>Remover 
                                </a>
                                <br />
                                <a class="btn btn-secondary" href="#" >
                                <i class="fa-solid fa-eye">
                                </i> Ver </a>
                            </div>
                        </td>
                        <td><img src="@ator.FotoPerfilURL" style="max-width:100px" alt="@ator.Nome"></td>
                        <td class="align-middle">@ator.Nome</td>
                        <td class="align-middle">@ator.Bio</td>
                     </tr>
                }
            </tbody>
        </table>

    </div>
</div>